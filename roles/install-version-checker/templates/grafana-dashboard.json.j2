{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "limit": 100,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": 12833,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Table showing the images in use on this cluster, the version in use, and the upstream latest version.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Is Latest" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "from": "", "id": 0, "text": "No", "to": "", "type": 1, "value": "0" },
                  { "from": "1", "id": 1, "text": "Yes", "to": "999999999", "type": 2, "value": "1" }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 25, "w": 16, "x": 0, "y": 0 },
      "id": 2,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Image" }]
      },
      "targets": [
        {
          "expr": "sum by(image,current_version,latest_version) (version_checker_is_latest_version)",
          "format": "time_series",
          "instant": true,
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Cluster Image Version Checks",
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "Time": 0, "Value": 4, "current_version": 2, "image": 1, "latest_version": 3 },
            "renameByName": { "Value": "Is Latest", "current_version": "Current Version", "image": "Image", "latest_version": "Latest Version" }
          }
        }
      ],
      "type": "table"
    }
  ],
  "schemaVersion": 25,
  "style": "dark",
  "tags": [],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "",
  "title": "version-checker",
  "uid": "Awr5zZ4Gk",
  "version": 3,
  "description": "Dashboard for version-checker — current vs latest container image versions. https://github.com/jetstack/version-checker"
}
