apiVersion: v1
kind: ConfigMap
metadata:
  name: hermes-gateway-config
  namespace: {{ hermes_namespace }}
data:
  gateway.json: |
    {
      "platforms": {
        "webhook": {
          "enabled": true,
          "extra": {
            "port": 8644,
            "secret": "hermes-webhook-secret",
            "routes": {
              "default": {
                "secret": "INSECURE_NO_AUTH",
                "prompt": "Hermes webhook is alive",
                "deliver": "log"
              }
            }
          }
        }
      }
    }
