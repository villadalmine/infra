apiVersion: v1
kind: ConfigMap
metadata:
  name: hermes-gateway-config
  namespace: {{ hermes_namespace }}
data:
  gateway.json: |
    {
      "platforms": {
        "telegram": {
          "enabled": true,
          "extra": {
            "allowed_users": "{{ hermes_telegram_allowed_users | default('') }}",
            "require_mention": true,
            "mention_patterns": [
              "^\\s*ask\\b",
              "^\\s*hermes\\b",
              "^\\s*tito\\b"
            ]
          }
        }
      }
    }
