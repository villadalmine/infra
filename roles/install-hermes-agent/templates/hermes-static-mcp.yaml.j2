apiVersion: v1
kind: ServiceAccount
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: hermes-agent-mcp-readonly
rules:
  - apiGroups: [""]
    resources: ["pods", "pods/log", "namespaces", "services", "configmaps", "nodes", "events"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps"]
    resources: ["deployments", "statefulsets", "daemonsets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["batch"]
    resources: ["jobs", "cronjobs"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: hermes-agent-mcp-readonly
subjects:
  - kind: ServiceAccount
    name: hermes-agent-mcp
    namespace: {{ hermes_namespace }}
roleRef:
  kind: ClusterRole
  name: hermes-agent-mcp-readonly
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes-agent-mcp
  template:
    metadata:
      labels:
        app: hermes-agent-mcp
    spec:
      serviceAccountName: hermes-agent-mcp
      nodeSelector:
        kubernetes.io/hostname: {{ hermes_node_hostname }}
      tolerations:
        - operator: Exists
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        runAsNonRoot: true
        fsGroup: 1000
      initContainers:
        - name: create-env-file
          image: busybox:latest
          command: ["sh", "-c"]
          args:
            - |
              cat <<EOF > /opt/data/.env
              OPENAI_API_KEY={{ hermes_openai_api_key }}
              OPENAI_API_BASE={{ hermes_openai_api_base }}
              EOF
              chmod 644 /opt/data/.env
          volumeMounts:
            - name: hermes-data
              mountPath: /opt/data
      containers:
        - name: hermes-agent
          image: {{ hermes_registry }}/{{ hermes_image_name }}:{{ hermes_image_tag }}
          imagePullPolicy: IfNotPresent
          workingDir: /opt/data
          command: ["hermes", "gateway", "run"]
          args: ["--replace"]
          env:
            - name: HOME
              value: /opt/data
            - name: HERMES_MODEL
              value: {{ hermes_model }}
            - name: HERMES_TEMPERATURE
              value: "{{ hermes_temperature }}"
            - name: OPENAI_API_BASE
              value: {{ hermes_openai_api_base }}
            - name: OPENAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: hermes-secrets
                  key: OPENAI_API_KEY
            - name: HERMES_HOME
              value: /opt/data
            - name: TELEGRAM_BOT_TOKEN
              valueFrom:
                secretKeyRef:
                  name: hermes-secrets
                  key: TELEGRAM_BOT_TOKEN
            - name: HERMES_SYSTEM_PROMPT
              value: |
                {{ hermes_system_prompt | indent(16) }}
            - name: GATEWAY_ALLOW_ALL_USERS
              value: "true"
            - name: TELEGRAM_ALLOWED_USERS
              value: "{{ hermes_telegram_allowed_users }}"
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          volumeMounts:
            - name: hermes-data
              mountPath: /opt/data
            - name: hermes-home
              mountPath: /opt/data/.hermes
            - name: tmp
              mountPath: /tmp
            - name: hermes-gateway-config
              mountPath: /opt/data/gateway.json
              subPath: gateway.json
            - name: hermes-config
              mountPath: /opt/data/config.yaml
              subPath: config.yaml
        - name: kubernetes-mcp-server
          image: {{ hermes_registry }}/{{ hermes_mcp_image_name }}:{{ hermes_mcp_image_tag }}
          imagePullPolicy: IfNotPresent
          command: ["sh", "-c"]
          args:
            - |
              # Generate kubeconfig for sidecar
              mkdir -p ~/.kube
              CA=$(cat /var/run/secrets/kubernetes.io/serviceaccount/ca.crt | base64 | tr -d '\n')
              TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
              cat <<EOF > ~/.kube/config
              apiVersion: v1
              kind: Config
              clusters:
              - cluster:
                  certificate-authority-data: ${CA}
                  server: https://kubernetes.default.svc
                name: cluster
              contexts:
              - context:
                  cluster: cluster
                  user: default
                name: default
              current-context: default
              users:
              - name: default
                user:
                  token: ${TOKEN}
              EOF
              exec /usr/local/bin/kubernetes-mcp-server --port 8080
          ports:
            - name: sse
              containerPort: 8080
              protocol: TCP
          env:
            - name: HOME
              value: /tmp
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          volumeMounts:
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: hermes-data
          emptyDir: {}
        - name: hermes-home
          emptyDir: {}
        - name: tmp
          emptyDir:
            sizeLimit: 128Mi
        - name: hermes-gateway-config
          configMap:
            name: hermes-gateway-config
        - name: hermes-config
          configMap:
            name: hermes-config
