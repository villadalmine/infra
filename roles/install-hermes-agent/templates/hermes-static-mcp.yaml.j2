apiVersion: v1
kind: Secret
metadata:
  name: hermes-secrets
  namespace: {{ hermes_namespace }}
type: Opaque
stringData:
  .env: |
    OPENROUTER_API_KEY={{ hermes_openrouter_api_key | default('') }}
    TELEGRAM_BOT_TOKEN={{ hermes_telegram_token | default('') }}
    TELEGRAM_ALLOWED_USERS={{ hermes_telegram_allowed_users }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: hermes-gateway-config
  namespace: {{ hermes_namespace }}
data:
  gateway.json: |
    {
      "platforms": {
        "telegram": {
          "enabled": {{ hermes_telegram_enabled | lower }},
          "extra": {
            "allowed_users": "{{ hermes_telegram_allowed_users }}",
            "require_mention": true,
            "mention_patterns": [
              "^\\s*ask\\b",
              "^\\s*hermes\\b"
            ]
          }
        }
      }
    }
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: hermes-config-mcp-test
  namespace: {{ hermes_namespace }}
data:
  config.yaml: |
    model:
      default: {{ hermes_model }}
      provider: {{ hermes_inference_provider }}

    fallback_model:
      provider: openrouter
      model: qwen/qwen3-coder:free

    agent:
      tool_use_enforcement: true
      system_prompt: |
        {{ hermes_system_prompt | indent(8) }}

    mcp_servers:
      kubernetes:
        url: {{ hermes_mcp_url }}
        timeout: {{ hermes_mcp_timeout }}
        connect_timeout: {{ hermes_mcp_connect_timeout }}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: hermes-agent-mcp-readonly
rules:
  - apiGroups: [""]
    resources: ["pods", "pods/log", "namespaces"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps", "batch"]
    resources: ["deployments", "replicasets", "statefulsets", "daemonsets", "jobs", "cronjobs"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: hermes-agent-mcp-readonly
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: hermes-agent-mcp-readonly
subjects:
  - kind: ServiceAccount
    name: hermes-agent-mcp
    namespace: {{ hermes_namespace }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: hermes-agent-mcp
  template:
    metadata:
      labels:
        app: hermes-agent-mcp
      annotations:
        hermes-config-rev: "1"
    spec:
      serviceAccountName: hermes-agent-mcp
      nodeSelector:
        kubernetes.io/hostname: {{ hermes_node_hostname }}
      tolerations:
        - operator: Exists
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        runAsNonRoot: true
        fsGroup: 1000
      containers:
        - name: hermes-agent
          image: {{ hermes_registry }}/{{ hermes_image_name }}:{{ hermes_image_tag }}
          imagePullPolicy: IfNotPresent
          workingDir: /opt/data
          command: ["hermes", "gateway", "run"]
          args: ["--replace"]
          env:
            - name: HOME
              value: /opt/data
            - name: HERMES_MODEL
              value: {{ hermes_model }}
            - name: HERMES_INFERENCE_PROVIDER
              value: {{ hermes_inference_provider }}
            - name: HERMES_TEMPERATURE
              value: "{{ hermes_temperature }}"
            - name: HERMES_HOME
              value: /opt/data
            - name: HERMES_SYSTEM_PROMPT
              value: |
                {{ hermes_system_prompt | indent(16) }}
            - name: GATEWAY_ALLOW_ALL_USERS
              value: "true"
            - name: TELEGRAM_ALLOWED_USERS
              value: "{{ hermes_telegram_allowed_users }}"
            - name: TELEGRAM_WEBHOOK_URL
              value: "{{ hermes_telegram_webhook_url }}"
          envFrom:
            - secretRef:
                name: hermes-secrets
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
          volumeMounts:
            - name: hermes-data
              mountPath: /opt/data
            - name: hermes-home
              mountPath: /opt/data/.hermes
            - name: hermes-config
              mountPath: /opt/data/config.yaml
              subPath: config.yaml
            - name: hermes-env
              mountPath: /opt/data/.env
              subPath: .env
            - name: hermes-gateway-config
              mountPath: /opt/data/gateway.json
              subPath: gateway.json
            - name: tmp
              mountPath: /tmp
        - name: kubernetes-mcp-server
          image: {{ hermes_registry }}/{{ hermes_mcp_image_name }}:{{ hermes_mcp_image_tag }}
          imagePullPolicy: IfNotPresent
          command: ["sh", "-lc"]
          args:
            - |
              cat >/tmp/hermes-kubeconfig <<EOF
              apiVersion: v1
              kind: Config
              clusters:
              - name: in-cluster
                cluster:
                  server: https://${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}
                  certificate-authority: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
              contexts:
              - name: in-cluster
                context:
                  cluster: in-cluster
                  user: hermes
              current-context: in-cluster
              users:
              - name: hermes
                user:
                  tokenFile: /var/run/secrets/kubernetes.io/serviceaccount/token
              EOF
              exec /usr/local/bin/kubernetes-mcp-server --port 8080 --kubeconfig /tmp/hermes-kubeconfig --cluster-provider kubeconfig --read-only --disable-multi-cluster --stateless
          ports:
            - name: sse
              containerPort: 8080
              protocol: TCP
          env:
            - name: HOME
              value: /tmp
          volumeMounts:
            - name: tmp
              mountPath: /tmp
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
      volumes:
        - name: hermes-data
          emptyDir: {}
        - name: hermes-home
          emptyDir: {}
        - name: hermes-config
          configMap:
            name: hermes-config-mcp-test
        - name: hermes-env
          secret:
            secretName: hermes-secrets
        - name: hermes-gateway-config
          configMap:
            name: hermes-gateway-config
        - name: tmp
          emptyDir:
            sizeLimit: 128Mi
---
apiVersion: v1
kind: Service
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
spec:
  type: ClusterIP
  selector:
    app: hermes-agent-mcp
  ports:
    - name: http
      port: 8644
      targetPort: 8644
      protocol: TCP
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: hermes-agent-mcp
  namespace: {{ hermes_namespace }}
spec:
  parentRefs:
    - name: cluster-gateway
      namespace: gateway
  hostnames:
    - hermes-mcp.cluster.home
  rules:
    - backendRefs:
        - name: hermes-agent-mcp
          port: 8644
---
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: hermes-agent-mcp-egress
  namespace: {{ hermes_namespace }}
spec:
  podSelector:
    matchLabels:
      app: hermes-agent-mcp
  policyTypes:
    - Egress
  egress:
    - ports:
        - port: 53
          protocol: UDP
        - port: 53
          protocol: TCP
    - to:
        - podSelector:
            matchLabels:
              app: litellm-proxy
      ports:
        - port: 4000
          protocol: TCP
    - ports:
        - port: 443
          protocol: TCP
        - port: 6443
          protocol: TCP
