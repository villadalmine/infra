FROM debian:13.4

# Install build/runtime dependencies
# python3-venv required: Debian 13 ships Python 3.13 with PEP 668 (externally managed).
# uv replaces pip for dependency resolution — pip's backtracking resolver gets stuck on
# packages with many versions (slack-sdk, slack-bolt) and can run for hours.
# uv resolves in seconds using a SAT solver.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 python3-pip python3-venv \
        python3-dev ripgrep ffmpeg gcc libffi-dev curl && \
    rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager) into /usr/local/bin
RUN curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/usr/local/bin sh

WORKDIR /opt/hermes

# Source is prepared in /workspace by the initContainer and copied in by kaniko.
COPY . /opt/hermes

# Create venv with uv, install all Python deps, then install Node deps.
RUN python3 -m venv /opt/venv && \
    /usr/local/bin/uv pip install --python /opt/venv/bin/python3 --no-cache ".[all]" && \
    npm install --prefer-offline --no-audit && \
    cd /opt/hermes/scripts/whatsapp-bridge && \
    npm install --prefer-offline --no-audit

WORKDIR /opt/hermes
RUN chmod +x /opt/hermes/docker/entrypoint.sh

# Put venv first in PATH so 'hermes', 'python3', etc. all resolve from the venv.
ENV PATH="/opt/venv/bin:$PATH"
ENV HERMES_HOME=/opt/data
VOLUME [ "/opt/data" ]
ENTRYPOINT [ "/opt/hermes/docker/entrypoint.sh" ]
