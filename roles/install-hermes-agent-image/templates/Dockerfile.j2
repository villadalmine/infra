FROM debian:13.4

# Install build/runtime dependencies
# python3-venv required: Debian 13 ships Python 3.13 with PEP 668 (externally managed).
# --break-system-packages installs packages but they don't land in sys.path consistently.
# Solution: use a proper venv so all deps are isolated and importable.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 python3-pip python3-venv \
        python3-dev ripgrep ffmpeg gcc libffi-dev && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt/hermes

# Source is prepared in /workspace by the initContainer and copied in by kaniko.
COPY . /opt/hermes

# Create venv, install all Python deps into it, then install Node deps.
RUN python3 -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir ".[all]" && \
    npm install --prefer-offline --no-audit && \
    cd /opt/hermes/scripts/whatsapp-bridge && \
    npm install --prefer-offline --no-audit

WORKDIR /opt/hermes
RUN chmod +x /opt/hermes/docker/entrypoint.sh

# Put venv first in PATH so 'hermes', 'python3', etc. all resolve from the venv.
ENV PATH="/opt/venv/bin:$PATH"
ENV HERMES_HOME=/opt/data
VOLUME [ "/opt/data" ]
ENTRYPOINT [ "/opt/hermes/docker/entrypoint.sh" ]
