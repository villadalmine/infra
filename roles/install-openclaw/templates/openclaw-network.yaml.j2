# Service — ClusterIP (never LoadBalancer per project rules)
apiVersion: v1
kind: Service
metadata:
  name: openclaw
  namespace: {{ openclaw_namespace }}
spec:
  type: ClusterIP
  selector:
    app: openclaw
  ports:
    - name: gateway
      port: {{ openclaw_gateway_port }}
      targetPort: gateway
      protocol: TCP
---
# HTTPRoute — Cilium Gateway at 192.168.178.200
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: openclaw
  namespace: {{ openclaw_namespace }}
spec:
  parentRefs:
    - name: cluster-gateway
      namespace: gateway
  hostnames:
    - {{ openclaw_hostname }}
  rules:
    - backendRefs:
        - name: openclaw
          port: {{ openclaw_gateway_port }}
---
# NetworkPolicy — restrict egress to known endpoints only
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: openclaw-egress
  namespace: {{ openclaw_namespace }}
spec:
  podSelector:
    matchLabels:
      app: openclaw
  policyTypes:
    - Egress
    - Ingress
  ingress:
    # AlertManager webhook (proactive alerts → OpenClaw → Telegram)
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: monitoring
      ports:
        - port: {{ openclaw_gateway_port }}
          protocol: TCP
  egress:
    # DNS
    - ports:
        - port: 53
          protocol: UDP
        - port: 53
          protocol: TCP
    # LiteLLM proxy (in-cluster — all LLM traffic)
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: ai
          podSelector:
            matchLabels:
              app: litellm-proxy
      ports:
        - port: 4000
          protocol: TCP
    # External HTTPS (Telegram API, OpenRouter if direct, etc.)
    - ports:
        - port: 443
          protocol: TCP
    # K8s API server (for kubernetes-mcp sidecar)
    - ports:
        - port: 6443
          protocol: TCP
    # Kagent — kagent-tools MCP server (port 8084, targetPort 8084)
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kagent
      ports:
        - port: 8084
          protocol: TCP
    # Hermes — subagente (port 8644 = service + targetPort)
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: ai
          podSelector:
            matchLabels:
              app: hermes-agent-mcp
      ports:
        - port: 8644
          protocol: TCP
    # Prometheus — queries de métricas read-only
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: monitoring
      ports:
        - port: 9090
          protocol: TCP
    # Red home — análisis de dispositivos read-only (Hue, cámaras, NAS)
    - to:
        - ipBlock:
            cidr: 192.168.178.0/24
      ports:
        - port: 80
          protocol: TCP
        - port: 443
          protocol: TCP
        - port: 8080
          protocol: TCP
        - port: 554
          protocol: TCP
