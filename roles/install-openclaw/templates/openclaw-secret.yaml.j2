apiVersion: v1
kind: Secret
metadata:
  name: openclaw-secrets
  namespace: {{ openclaw_namespace }}
type: Opaque
stringData:
  OPENCLAW_GATEWAY_TOKEN: "{{ openclaw_gateway_token | default('') }}"
  TELEGRAM_BOT_TOKEN: "{{ openclaw_telegram_token | default('') }}"
  TELEGRAM_ALLOWED_USERS: "{{ openclaw_telegram_allowed_users | default('') }}"
{% if openclaw_llm_backend == 'openrouter' %}
  OPENROUTER_API_KEY: "{{ openclaw_openrouter_api_key | default('') }}"
{% endif %}
