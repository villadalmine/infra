# Copy this file to secrets.yml and fill in your real values.
# secrets.yml is gitignored — NEVER commit tokens to the repo.
#
#   cp roles/install-openclaw/defaults/secrets.yml.example \
#      roles/install-openclaw/defaults/secrets.yml
#   vim roles/install-openclaw/defaults/secrets.yml

# ─── Gateway auth token ───────────────────────────────────────────────────────
# Clients authenticate with this token (macOS app, CLI, mobile).
# Generate: openssl rand -hex 32
openclaw_gateway_token: "CHANGE_ME_openssl_rand_-hex_32"

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather → /newbot
openclaw_telegram_token: "123456:ABC-DEF-REPLACE-ME"
# Your Telegram user ID — find via @myidbot or @userinfobot
openclaw_telegram_allowed_users: "YOUR_TELEGRAM_USER_ID"

# ─── Optional: direct OpenRouter key ──────────────────────────────────────────
# Only needed if openclaw_llm_backend: "openrouter" (bypasses LiteLLM).
# Default backend is LiteLLM (in-cluster proxy) — key not needed.
# openclaw_openrouter_api_key: "sk-or-v1-..."
