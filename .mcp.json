{
  "mcpServers": {
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@latest"],
      "env": {
        "KUBECONFIG": "${HOME}/.kube/config"
      }
    },
    "cluster-advisor": {
      "command": "python",
      "args": ["mcp/cluster-advisor/server.py"]
    }
  }
}
