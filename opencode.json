{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/default",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (local — start with: mise run litellm)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "sk-infra-local"
      },
      "models": {
        "default": {
          "name": "Default (claude-sonnet via OpenRouter, fallback to cheap)",
          "tools": true
        },
        "claude-sonnet": {
          "name": "Claude Sonnet 4.5 (via OpenRouter)",
          "tools": true
        },
        "claude-opus": {
          "name": "Claude Opus 4 (via OpenRouter)",
          "tools": true
        },
        "gemini-flash": {
          "name": "Gemini 1.5 Flash (via OpenRouter)",
          "tools": true
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini (via OpenRouter)",
          "tools": true
        },
        "free": {
          "name": "Free tier (qwen3-coder:free → nemotron:free → qwen-turbo)",
          "tools": true
        },
        "cheap": {
          "name": "Cheap (qwen-turbo via OpenRouter)",
          "tools": true
        }
      }
    }
  },
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest"],
      "environment": {
        "KUBECONFIG": "${HOME}/.kube/config"
      }
    },
    "cluster-advisor": {
      "type": "local",
      "command": ["python", "mcp/cluster-advisor/server.py"]
    }
  }
}
